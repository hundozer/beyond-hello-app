w-10 h-10 bg-gradient-to-tr from-[#FF6B35] to-[#FF9F1C] rounded-xl flex items-center justify-center text-white font-bold text-xl\\\">B</div><span class=\\\"text-2xl font-black tracking-tight text-[#FF6B35]\\\">Beyond Hello</span></div><div class=\\\"flex items-center space-x-4\\\"><div class=\\\"bg-white/60 backdrop-blur-md px-4 py-2 rounded-full border border-white/40 shadow-sm flex items-center space-x-2\\\"><span class=\\\"w-2 h-2 bg-green-500 rounded-full animate-pulse\\\"></span><span class=\\\"text-xs font-bold uppercase tracking-wider\\\">Launching in Prague Soon</span></div></div></header><main class=\\\"flex-1 px-12 grid grid-cols-12 gap-8 items-center\\\"><div class=\\\"col-span-4 space-y-8\\\"><div class=\\\"space-y-4\\\"><h1 class=\\\"text-6xl font-black leading-[1.1] tracking-tight\\\">A social experience <span class=\\\"text-[#FF6B35]\\\">for singles.</span></h1><p class=\\\"text-lg text-slate-600 leading-relaxed\\\">Meet people differently. Discover Prague through challenges, experiences, and moments that create real connections.</p></div><div class=\\\"space-y-4\\\"><div class=\\\"flex items-center space-x-4\\\"><div class=\\\"bg-white shadow-xl rounded-3xl p-6 w-full border border-slate-100\\\"><div class=\\\"flex justify-between items-center mb-4 text-xs font-bold text-slate-400 uppercase tracking-widest\\\"><span>Old Way</span><span>New Way</span></div><div class=\\\"flex justify-between items-center\\\"><div class=\\\"flex flex-col items-center opacity-40\\\"><span class=\\\"text-2xl\\\">\342\235\214</span><span class=\\\"text-[10px] mt-1\\\">Swiping</span></div><div class=\\\"h-px bg-slate-100 w-12\\\"></div><div class=\\\"flex flex-col items-center\\\"><span class=\\\"text-2xl\\\">\342\234\205</span><span class=\\\"text-[10px] mt-1\\\">Living</span></div></div></div></div><div class=\\\"flex space-x-3\\\"><div class=\\\"bg-black text-white px-5 py-3 rounded-xl flex items-center space-x-2\\\"><div class=\\\"w-5 h-5 bg-white rounded-full flex items-center justify-center\\\"><div class=\\\"w-1 h-1 bg-black rounded-full\\\"></div></div><div class=\\\"flex flex-col\\\"><span class=\\\"text-[8px] uppercase leading-none opacity-60\\\">Coming soon on</span><span class=\\\"text-sm font-bold leading-none\\\">App Store</span></div></div><div class=\\\"bg-black text-white px-5 py-3 rounded-xl flex items-center space-x-2\\\"><div class=\\\"w-5 h-5 bg-white/20 rounded-full\\\"></div><div class=\\\"flex flex-col\\\"><span class=\\\"text-[8px] uppercase leading-none opacity-60\\\">Coming soon on</span><span class=\\\"text-sm font-bold leading-none\\\">Google Play</span></div></div></div></div></div><div class=\\\"col-span-4 flex justify-center relative\\\"><div class=\\\"w-[320px] h-[640px] bg-[#1A1A1A] rounded-[50px] p-4 border-[8px] border-slate-800 shadow-2xl relative overflow-hidden ring-4 ring-white/20\\\"><div class=\\\"absolute top-0 left-1/2 -translate-x-1/2 w-32 h-6 bg-slate-800 rounded-b-2xl z-20\\\"></div><div class=\\\"w-full h-full bg-white rounded-[32px] overflow-hidden flex flex-col\\\"><div class=\\\"p-6 space-y-4\\\"><div class=\\\"flex justify-between items-center\\\"><span class=\\\"text-lg font-black\\\">Discover</span><div class=\\\"w-8 h-8 rounded-full bg-slate-100\\\"></div></div><div class=\\\"bg-[#FFF0EB] rounded-2xl p-4 space-y-3 border border-[#FF6B35]/10\\\"><div class=\\\"flex justify-between\\\"><span class=\\\"bg-[#FF6B35] text-white text-[10px] font-bold px-2 py-1 rounded-md uppercase\\\">Live Now</span><span class=\\\"text-xs font-bold text-[#FF6B35]\\\">Vinohrady</span></div><h3 class=\\\"text-xl font-bold leading-tight\\\">\342\230\225 Coffee Quest Challenge</h3><p class=\\\"text-xs text-slate-600\\\">Find Prague\'s most interesting caf\303\251 with 3 new matches.</p><button class=\\\"w-full bg-[#FF6B35] text-white py-3 rounded-xl font-bold text-sm shadow-lg shadow-[#FF6B35]/20\\\">Join Experience</button></div><div class=\\\"space-y-3\\\"><h4 class=\\\"text-sm font-bold text-slate-400 uppercase tracking-wider\\\">Suggested for you</h4><div class=\\\"bg-slate-50 rounded-2xl p-4 border border-slate-100 flex items-center space-x-3\\\"><div class=\\\"w-12 h-12 bg-slate-200 rounded-lg\\\"></div><div class=\\\"flex-1\\\"><div class=\\\"text-sm font-bold\\\">City Explorer</div><div class=\\\"text-[10px] text-slate-500\\\">Photo challenge in Mal\303\241 Strana</div></div></div><div class=\\\"bg-slate-50 rounded-2xl p-4 border border-slate-100 flex items-center space-x-3\\\"><div class=\\\"w-12 h-12 bg-slate-200 rounded-lg\\\"></div><div class=\\\"flex-1\\\"><div class=\\\"text-sm font-bold\\\">Taste Adventure</div><div class=\\\"text-[10px] text-slate-500\\\">Group dinner at Manifesto</div></div></div></div></div></div></div><div class=\\\"absolute -right-12 top-1/4 w-32 h-32 bg-[#4ECDC4]/20 rounded-full blur-2xl\\\"></div><div class=\\\"absolute -left-12 bottom-1/4 w-32 h-32 bg-[#FF6B35]/20 rounded-full blur-2xl\\\"></div></div><div class=\\\"col-span-4 space-y-6\\\"><div class=\\\"bg-white/40 backdrop-blur-xl border border-white/60 p-8 rounded-[40px] shadow-sm space-y-6\\\"><div class=\\\"space-y-1\\\"><h2 class=\\\"text-2xl font-black\\\">Join the first 1,000 members</h2><p class=\\\"text-sm text-slate-500\\\">Help shape the future of social connection in Prague.</p></div><form class=\\\"space-y-4\\\"><div class=\\\"grid grid-cols-2 gap-3\\\"><input type=\\\"text\\\" placeholder=\\\"First Name\\\" class=\\\"bg-white/80 border-none ring-1 ring-slate-200 rounded-xl px-4 py-3 text-sm focus:ring-[#FF6B35] outline-none\\\"><input type=\\\"email\\\" placeholder=\\\"Email\\\" class=\\\"bg-white/80 border-none ring-1 ring-slate-200 rounded-xl px-4 py-3 text-sm focus:ring-[#FF6B35] outline-none\\\"></div><select class=\\\"w-full bg-white/80 border-none ring-1 ring-slate-200 rounded-xl px-4 py-3 text-sm outline-none text-slate-400\\\"><option>What are you looking for?</option><option>New Experiences</option><option>Deep Connections</option><option>Something Fun</option></select><button class=\\\"w-full bg-slate-900 text-white py-4 rounded-2xl font-bold tracking-tight shadow-xl\\\">Reserve my place</button></form><div class=\\\"flex items-center justify-center space-x-2 text-[10px] font-bold text-slate-400 uppercase tracking-widest\\\"><span class=\\\"w-8 h-px bg-slate-200\\\"></span><span>Be adventurous</span><span class=\\\"w-8 h-px bg-slate-200\\\"></span></div></div><div class=\\\"grid grid-cols-2 gap-4\\\"><div class=\\\"bg-[#F5F1FF] p-5 rounded-3xl space-y-2\\\"><span class=\\\"text-2xl\\\">\342\234\250</span><h4 class=\\\"font-bold text-sm leading-tight\\\">More than a profile</h4><p class=\\\"text-[10px] text-slate-500\\\">Connect through personality and shared action.</p></div><div class=\\\"bg-[#EBF7FF] p-5 rounded-3xl space-y-2\\\"><span class=\\\"text-2xl\\\">\360\237\214\215</span><h4 class=\\\"font-bold text-sm leading-tight\\\">Discover Prague</h4><p class=\\\"text-[10px] text-slate-500\\\">Explore hidden spots in the city you love.</p></div></div></div></main><footer class=\\\"px-12 py-6 flex justify-between items-center bg-white/30 backdrop-blur-md border-t border-white/50\\\"><div class=\\\"flex space-x-8 text-[11px] font-bold uppercase tracking-widest text-slate-400\\\"><span>How it works</span><span>Challenges</span><span>Safety</span><span>Privacy</span></div><div class=\\\"text-[11px] font-bold text-slate-400\\\">\302\251 2024 Beyond Hello. Built with \342\235\244\357\270\217 for Prague.</div></footer></div>\\n  </body>\\n</html>\n[AIS_METADATA_SECTION_END]"
    items {
