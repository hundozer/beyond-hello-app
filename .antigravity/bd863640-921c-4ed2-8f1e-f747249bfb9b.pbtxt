          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "import { "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  CheckCircle, Ticket, Users, AlertCircle, Share2, "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
