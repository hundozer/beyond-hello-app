er justify-center\\\"><div class=\\\"w-1 h-1 bg-black rounded-full\\\"></div></div><div class=\\\"flex flex-col\\\"><span class=\\\"text-[8px] uppercase leading-none opacity-60\\\">Coming soon on</span><span class=\\\"text-sm font-bold leading-none\\\">App Store</span></div></div><div class=\\\"bg-black text-white px-5 py-3 rounded-xl flex items-center space-x-2\\\"><div class=\\\"w-5 h-5 bg-white/20 rounded-full\\\"></div><div class=\\\"flex flex-col\\\"><span class=\\\"text-[8px] uppercase leading-none opacity-60\\\">Coming soon on</span><span class=\\\"text-sm font-bold leading-none\\\">Google Play</span></div></div></div></div></div><div class=\\\"col-span-4 flex justify-center relative\\\"><div class=\\\"w-[320px] h-[640px] bg-[#1A1A1A] rounded-[50px] p-4 border-[8px] border-slate-800 shadow-2xl relative overflow-hidden ring-4 ring-white/20\\\"><div class=\\\"absolute top-0 left-1/2 -translate-x-1/2 w-32 h-6 bg-slate-800 rounded-b-2xl z-20\\\"></div><div class=\\\"w-full h-full bg-white rounded-[32px] overflow-hidden flex flex-col\\\"><div class=\\\"p-6 space-y-4\\\"><div class=\\\"flex justify-between items-center\\\"><span class=\\\"text-lg font-black\\\">Discover</span><div class=\\\"w-8 h-8 rounded-full bg-slate-100\\\"></div></div><div class=\\\"bg-[#FFF0EB] rounded-2xl p-4 space-y-3 border border-[#FF6B35]/10\\\"><div class=\\\"flex justify-between\\\"><span class=\\\"bg-[#FF6B35] text-white text-[10px] font-bold px-2 py-1 rounded-md uppercase\\\">Live Now</span><span class=\\\"text-xs font-bold text-[#FF6B35]\\\">Vinohrady</span></div><h3 class=\\\"text-xl font-bold leading-tight\\\">\342\230\225 Coffee Quest Challenge</h3><p class=\\\"text-xs text-slate-600\\\">Find Prague\'s most interesting caf\303\251 with 3 new matches.</p><button class=\\\"w-full bg-[#FF6B35] text-white py-3 rounded-xl font-bold text-sm shadow-lg shadow-[#FF6B35]/20\\\">Join Experience</button></div><div class=\\\"space-y-3\\\"><h4 class=\\\"text-sm font-bold text-slate-400 upperca